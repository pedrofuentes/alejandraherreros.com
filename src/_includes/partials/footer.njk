<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <a class="brand" href="/" aria-label="{{ site.name }} — inicio">
        <span class="brand__mark" aria-hidden="true">A<span class="dot">.</span>H</span>
        <span class="brand__text">
          <span class="brand__name">{{ site.shortName }}</span>
          <span class="brand__tagline">Física · Matemática</span>
        </span>
      </a>
      <p>{{ site.description }}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Navegación secundaria">
      <h2>Secciones</h2>
      <ul>
        {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-footer__cta">
      <h2>Contacto</h2>
      <p>Cuéntame qué necesitas reforzar y armamos un plan claro.</p>
      <a class="btn" href="/contact-us/">Escríbeme</a>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <p>© {% year %} {{ site.name }} · Profesora particular de Física y Matemática</p>
  </div>
</footer>
