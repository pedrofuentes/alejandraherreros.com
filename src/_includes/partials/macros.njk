{#
  Editorial component macros — "cuaderno científico".
  Helpers (button, linkUnderline) are defined first so other macros can call them.
#}

{#  button(label, url, variant='primary')  variants: primary | ghost | on-ink  #}
{% macro button(label, url, variant='primary') %}
{%- set cls = 'btn' -%}
{%- if variant == 'ghost' -%}{% set cls = 'btn btn--ghost' %}{%- elif variant == 'on-ink' -%}{% set cls = 'btn btn--on-ink' %}{%- endif -%}
<a class="{{ cls }}" href="{{ url }}">{{ label }}</a>
{% endmacro %}

{#  linkUnderline(label, url) — editorial underlined mono link with arrow  #}
{% macro linkUnderline(label, url) %}
<a class="link-underline" href="{{ url }}">{{ label }}</a>
{% endmacro %}

{#
  hero(eyebrow, title, lead, meta, primaryUrl, primaryLabel, secondaryUrl, secondaryLabel,
       portrait, portraitAlt, caption, equation)
  Editorial home hero: mono kicker, Fraunces headline (title may contain <span class="accent">),
  Newsreader lead, mono meta list, ink+ghost CTAs, and a real portrait framed on graph paper.
#}
{% macro hero(eyebrow, title, lead, meta, primaryUrl, primaryLabel, secondaryUrl, secondaryLabel, portrait, portraitAlt, caption, equation) %}
<section class="hero">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="label hero__eyebrow label--plain reveal reveal--1">{{ eyebrow }}</p>
      <h1 class="hero__title reveal reveal--1">{{ title | safe }}</h1>
      <p class="hero__lead reveal reveal--2">{{ lead }}</p>
      {% if meta %}
        <ul class="hero__meta reveal reveal--2">
          {% for m in meta %}<li>{{ m }}</li>{% endfor %}
        </ul>
      {% endif %}
      <div class="button-row reveal reveal--3">
        {% if primaryUrl %}{{ button(primaryLabel, primaryUrl, 'primary') | trim }}{% endif %}
        {% if secondaryUrl %}{{ button(secondaryLabel, secondaryUrl, 'ghost') | trim }}{% endif %}
      </div>
    </div>
    <figure class="hero__figure reveal reveal--3">
      {% if equation %}<span class="hero__equation" aria-hidden="true">{{ equation }}</span>{% endif %}
      <img class="hero__portrait" src="{{ portrait }}" alt="{{ portraitAlt }}" width="480" height="600" fetchpriority="high" />
      {% if caption %}<figcaption class="hero__caption"><span class="tick" aria-hidden="true">●</span>{{ caption }}</figcaption>{% endif %}
    </figure>
  </div>
</section>
{% endmacro %}

{#
  section(label, title, intro, variant='default') ... endcall
  General editorial section: mono label, Fraunces title, lead intro, then caller content.
  variant 'tint' adds a warm ruled band.
#}
{% macro section(label, title, intro, variant='default') %}
<section class="section{% if variant != 'default' %} section--{{ variant }}{% endif %}">
  <div class="container">
    {% if label or title or intro %}
      <div class="section__header">
        {% if label %}<p class="label">{{ label }}</p>{% endif %}
        {% if title %}<h2 class="section__title">{{ title }}</h2>{% endif %}
        {% if intro %}<p class="section__intro">{{ intro }}</p>{% endif %}
      </div>
    {% endif %}
    {{ caller() }}
  </div>
</section>
{% endmacro %}

{#  cardGrid(columns='3') ... endcall — responsive grid (2 or 3)  #}
{% macro cardGrid(columns='3') %}
<div class="card-grid card-grid--{{ columns }}">
  {{ caller() }}
</div>
{% endmacro %}

{#  ficha(label, title, text, url='', linkLabel='Leer más') — index-card style feature  #}
{% macro ficha(label, title, text, url='', linkLabel='Leer más') %}
<article class="ficha">
  {% if label %}<p class="ficha__label">{{ label }}</p>{% endif %}
  <h3 class="ficha__title">{{ title }}</h3>
  <p class="ficha__text">{{ text }}</p>
  {% if url %}<p class="ficha__link">{{ linkUnderline(linkLabel, url) | trim }}</p>{% endif %}
</article>
{% endmacro %}

{#  programCard(title, count, items) — PDT program "ficha" with a ruled list  #}
{% macro programCard(title, count, items) %}
<article class="program-card">
  <div class="program-card__head">
    <h3>{{ title }}</h3>
    <span class="program-card__count">{{ count }}</span>
  </div>
  <ul>
    {% for it in items %}<li>{{ it | safe }}</li>{% endfor %}
  </ul>
</article>
{% endmacro %}

{#  quote(text, author, role='') — testimonial card  #}
{% macro quote(text, author, role='') %}
<figure class="quote">
  <blockquote>{{ text }}</blockquote>
  <figcaption><strong>{{ author }}</strong>{% if role %} · {{ role }}{% endif %}</figcaption>
</figure>
{% endmacro %}

{#
  cta(note, title, text, primaryUrl, primaryLabel, secondaryUrl='', secondaryLabel='')
  Ink block on graph paper with an ochre button.
#}
{% macro cta(note, title, text, primaryUrl, primaryLabel, secondaryUrl='', secondaryLabel='') %}
<section class="cta">
  <div class="container">
    <div class="cta__panel">
      <div>
        {% if note %}<p class="cta__note">{{ note }}</p>{% endif %}
        <h2 class="cta__title">{{ title }}</h2>
        <p class="cta__text">{{ text }}</p>
      </div>
      <div class="button-row">
        {{ button(primaryLabel, primaryUrl, 'on-ink') | trim }}
        {% if secondaryUrl %}{{ button(secondaryLabel, secondaryUrl, 'ghost') | trim }}{% endif %}
      </div>
    </div>
  </div>
</section>
{% endmacro %}
